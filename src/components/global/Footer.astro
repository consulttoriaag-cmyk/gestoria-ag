---
import OptimizedImage from "../../layouts/utilities/OptimizedImage.astro";
---

<footer class="bg-white border-t border-gray-200 mt-20">
  <div class="px-6 md:px-12 lg:px-24 py-12 max-w-7xl mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-10">
      <div class="md:col-span-2">
        <a href="/" class="inline-flex items-center gap-3">
          <OptimizedImage width={40} src="/logo.png" alt="Gestoría AG logo" />
          <span class="text-lg font-semibold text-gray-900">Gestoría AG</span>
        </a>
        <p class="mt-4 text-sm text-gray-600">
          Especialistas en trámites gubernamentales en Cuernavaca, Morelos.
          Gestionamos actas del registro civil, consultas SINDO, CURP, RFC,
          apostillas y más, para que evites filas y pérdida de tiempo.
        </p>
        <div class="mt-4 text-sm text-gray-600 space-y-1">
          <p><span class="font-semibold">Teléfono:</span> +52 777 514 1857</p>
          <p>
            <span class="font-semibold">Dirección:</span> 62000 Cuernavaca,
            Morelos
          </p>
          <p>
            <span class="font-semibold">WhatsApp:</span>
            <a
              href="https://wa.me/527775141857"
              class="text-blue-900 hover:underline">
              Enviar mensaje
            </a>
          </p>
        </div>
      </div>

      <div>
        <h4 class="text-sm font-semibold text-gray-900 mb-3">Servicios</h4>
        <ul class="space-y-2 text-sm text-gray-600">
          <li>Actas del Registro Civil</li>
          <li>Consultas SINDO</li>
          <li>CURP y RFC</li>
          <li>Apostillas</li>
        </ul>
      </div>

      <div>
        <h4 class="text-sm font-semibold text-gray-900 mb-3">Información</h4>
        <ul class="space-y-2 text-sm text-gray-600">
          <li>
            <a href="/servicios" class="hover:text-blue-900">Servicios</a>
          </li>
          <li>
            <a href="/contacto" class="hover:text-blue-900">Contacto</a>
          </li>
          <li>
            <a href="/terms" class="hover:text-blue-900">Términos</a>
          </li>
          <li>
            <a href="/privacy" class="hover:text-blue-900">Privacidad</a>
          </li>
        </ul>
      </div>
    </div>

    <div
      class="pt-8 mt-10 border-t border-gray-200 flex flex-col md:flex-row justify-between items-center text-xs text-gray-400 gap-2">
      <p>
        &copy; {new Date().getFullYear()} Gestoría AG. Todos los derechos
        reservados.
      </p>
      <p class="text-gray-400">
        Sitio informativo. Para cotizaciones y disponibilidad, contáctanos por
        WhatsApp.
      </p>
    </div>
  </div>
</footer>
