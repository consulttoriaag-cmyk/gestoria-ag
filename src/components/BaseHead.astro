---
import "../styles/global.css";
---

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />

<!-- Basic Meta Tags -->
<title>Gestoría AG - Trámites gubernamentales en Cuernavaca</title>
<meta
  name="description"
  content="Especialistas en actas del registro civil, consultas SINDO, CURP y RFC. Servicio rápido y confiable en Cuernavaca, Morelos."
/>
<meta name="keywords" content="gestoría cuernavaca, trámites administrativos, actas registro civil, SINDO, CURP, RFC, servicio remoto" />
<meta name="author" content="Your Name or Company Name" />

<!-- Favicons -->
<link rel="icon" href="/favicon.ico" sizes="any" />

<!-- Favicon / secondary icon -->
<link rel="shortcut icon" href="/logo.png" type="image/png" />

<!-- Open Graph / Facebook -->
<meta property="og:image" content="/og-image.png" />
<meta property="og:type" content="website" />
<meta property="og:url" content="https://gestoriaag.com/" />
<meta
  property="og:title"
  content="Gestoría AG - Trámites gubernamentales en Cuernavaca"
/>
<meta
  property="og:description"
  content="Trámites gubernamentales sin complicaciones: actas, SINDO, CURP, RFC y más."
/>
<meta
  property="og:image"
  content="https://gestoriaag.com/og-image.png"
/>

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content="https://gestoriaag.com/" />
<meta
  property="twitter:title"
  content="Gestoría AG - Trámites gubernamentales en Cuernavaca"
/>
<meta
  property="twitter:description"
  content="Trámites gubernamentales sin complicaciones: actas, SINDO, CURP, RFC y más."
/>
<meta
  property="twitter:image"
  content="https://gestoriaag.com/og-image.png"
/>

<!-- Canonical URL -->
<link rel="canonical" href="https://gestoriaag.com/" />

<!-- Additional SEO -->
<meta name="robots" content="index, follow" />
<meta name="googlebot" content="index, follow" />

<!-- Apple Touch Icon (already included in favicons, but keeping for backwards compatibility) -->
<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

<!-- Theme Color for Mobile Browsers -->
<meta name="theme-color" content="#ffffff" />

<!---- Alpine  -->
<script is:inline defer src="https://unpkg.com/alpinejs@3.10.5/dist/cdn.min.js">
</script>
